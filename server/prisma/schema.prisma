datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("Receptionist")
  room      String   @default("Examination Room 1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id           String    @id @default(uuid())
  name         String
  token        Int       @unique @default(autoincrement())
  status       String    @default("waiting") // 'waiting', 'calling', 'completed', 'no-show'
  purpose      String    @default("General Consultation")
  priority     String    @default("normal") // 'normal', 'urgent'
  joinedAt     DateTime  @default(now())
  calledAt     DateTime?
  assignedRoom String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model QueueSettings {
  id                      String   @id @default("singleton")
  averageConsultationTime Int      @default(15)
  updatedAt               DateTime @updatedAt
}
