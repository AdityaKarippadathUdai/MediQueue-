datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Receptionist {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TokenStatus {
  WAITING
  CALLED
  COMPLETED
  CANCELLED
}

model Department {
  id            String          @id @default(uuid())
  name          String
  code          String          @unique // e.g. "GEN", "CARD", "PEDI"
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  tokens        QueueToken[]
  queueSettings QueueSettings[]
}

model QueueToken {
  id           String      @id @default(uuid())
  tokenNumber  Int
  patientName  String
  patientPhone String
  status       TokenStatus @default(WAITING)
  date         String      // Format: YYYY-MM-DD. Enables daily resets and composite uniqueness.
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // A token number is unique within a specific department on a specific day
  @@unique([tokenNumber, date, departmentId])
  // Indices to maintain ordering and speed up query filters
  @@index([date, departmentId, tokenNumber])
}

model QueueSettings {
  id              String     @id @default(uuid())
  currentToken    Int        @default(0)
  lastIssuedToken Int        @default(0)
  resetDate       String     // Format: YYYY-MM-DD. Tracks when the last daily reset occurred.
  departmentId    String     @unique // One settings profile per department
  department      Department @relation(fields: [departmentId], references: [id])
  updatedAt       DateTime   @updatedAt
}
